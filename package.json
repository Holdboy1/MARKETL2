{
  "name": "marketplace-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @marketplace-platform/web",
    "dev:admin": "npm run dev --workspace @marketplace-platform/admin",
    "dev:bot": "npm run dev --workspace @marketplace-platform/bot",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
